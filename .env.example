# === DISCORD ===
# Token del bot (Discord Developer Portal -> Tu App -> Bot -> Token)
DISCORD_TOKEN=tu_discord_token_aqui

# ID de la aplicación (Discord Developer Portal -> Tu App -> Application ID)
CLIENT_ID=tu_client_id_aqui

# ID del servidor donde probar (clic derecho en el servidor -> Copiar ID)
# Solo necesario para deploy de comandos en desarrollo
GUILD_ID=tu_guild_id_aqui

# === SPOTIFY ===
# Credenciales de Spotify API (https://developer.spotify.com/dashboard)
# Crea una app -> Client ID y Client Secret
SPOTIFY_CLIENT_ID=tu_spotify_client_id_aqui
SPOTIFY_CLIENT_SECRET=tu_spotify_client_secret_aqui
